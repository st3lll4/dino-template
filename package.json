{
  "name": "extension",
  "version": "1.0.0",
  "description": "",
  "main": "index.ts",
  "scripts": {
    "dev": "npm-run-all --parallel dev:build dev:serve",
    "dev:build": "cross-env BROWSER=chrome-mv3 vite build --watch",
    "dev:serve": "cross-env BROWSER=chrome-mv3 vite",
    "dev:firefox": "npm-run-all --parallel dev:build:firefox dev:serve:firefox",
    "dev:build:firefox": "cross-env BROWSER=firefox-mv2 vite build --watch",
    "dev:serve:firefox": "cross-env BROWSER=firefox-mv2 vite",
    "build": "cross-env BROWSER=chrome-mv3 vite build",
    "build:firefox": "cross-env BROWSER=firefox-mv2 vite build",
    "build:firefox-mv3": "cross-env BROWSER=firefox-mv3 vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "Stella Tukia",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.1",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "ws": "^8.19.0"
  }
}
