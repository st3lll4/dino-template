{
  "manifest_version": 3,
  "name": "extension",
  "version": "1.0",
  "description": "small extension to test template",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  }
}
