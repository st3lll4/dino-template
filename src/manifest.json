{
  "manifest_version": 3,
  "name": "extension",
  "version": "1.0",
  "description": "small extension to test template",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "tabs"],
  "action": {
    "default_popup": "entrypoints/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["modules/*.js", "index.js", "modulepreload-polyfill.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "entrypoints/sidepanel/sidepanel.html"
  }
}
