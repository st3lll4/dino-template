{
  "manifest_version": 3,
  "name": "dino-template@st31114",
  "version": "1.0",
  "description": "A small browser extension template, built with TypeScript and Vite. Supports both Chrome and Firefox, has HMR, type safe messaging and API queries and minimal outside deps for the best development experience.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": ["https://random-d.uk/*", "https://httpbin.org/*"],
  "action": {
    "default_popup": "entrypoints/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["modules/*.js", "index.js", "modulepreload-polyfill.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "entrypoints/sidepanel/sidepanel.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "dino-template@st3lll4"
    }
  }
}
